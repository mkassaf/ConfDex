# Copy this to .env and fill in the values you need.
# Keys can also be entered directly in the web UI per job.

# ── Security ──────────────────────────────────────────────────────────────────
# Credentials for the web UI (leave ADMIN_PASSWORD blank to disable authentication)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── HTTPS with a domain (docker-compose.https.yml) ───────────────────────────
# Your domain name — must have an A record pointing to this server
DOMAIN=

# ── HTTPS with self-signed cert / IP address (docker-compose.selfsigned.yml) ─
# Your server's public IP address (used in the certificate's subjectAltName)
HOST_IP=

# ── Remote LLM API keys ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# freeinference.org (OpenAI-compatible) — models selected as freeinference/<model>
FREEINFERENCE_API_KEY=
