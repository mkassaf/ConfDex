# Copy this to .env and fill in the values you need.
# Keys can also be entered directly in the web UI per job.

# ── Security ──────────────────────────────────────────────────────────────────
# Admin password for the web UI (leave blank to disable authentication)
ADMIN_PASSWORD=

# ── HTTPS (only needed when using docker-compose.https.yml) ──────────────────
# Your domain name — must have an A record pointing to this server
DOMAIN=

# ── Remote LLM API keys ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
